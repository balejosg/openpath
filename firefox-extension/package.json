{
  "name": "@openpath/firefox-extension",
  "version": "1.0.0",
  "description": "OpenPath Firefox Extension for blocked domain handling",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "clean:all": "rm -rf dist *.tsbuildinfo",
    "prebuild": "npm run clean:all",
    "build": "tsc -p tsconfig.build.json",
    "build:cached": "npm run prebuild && npx turbo run build --filter=@openpath/firefox-extension",
    "build:chromium-managed": "node build-chromium-managed.mjs",
    "build:firefox-release": "node build-firefox-release.mjs",
    "release:payload-hash": "node firefox-release-payload-hash.mjs",
    "sign:firefox-release": "node sign-firefox-release.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "dev": "tsc --watch",
    "test": "npx tsx --test tests/*.test.ts",
    "test:coverage": "node ../scripts/run-c8-coverage.js \"npx tsx --test tests/*.test.ts\""
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/webextension-polyfill": "^0.12.1",
    "c8": "^10.1.3",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "web-ext": "10.1.0",
    "webextension-polyfill": "^0.12.0"
  },
  "c8": {
    "check-coverage": true,
    "lines": 65,
    "functions": 65,
    "branches": 55,
    "reporter": [
      "text",
      "lcov",
      "json"
    ],
    "include": [
      "src/**/*.ts"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
