# Docker image for Linux student-policy E2E runs.
# Provides a systemd-based Linux client environment plus Firefox, geckodriver,
# Node.js, and the Selenium suite used by the student-policy workflow.

FROM node:20-bookworm-slim AS node-runtime

FROM ubuntu:22.04

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive
ENV container=docker
ENV GECKODRIVER_VERSION=0.36.0

COPY --from=node-runtime /usr/local /usr/local

COPY linux/lib/apt.sh /tmp/openpath-apt.sh
RUN . /tmp/openpath-apt.sh \
    && apt_install_with_retry "student policy base packages" apt-get install -y \
    bzip2 \
    ca-certificates \
    curl \
    dbus \
    fonts-liberation \
    iproute2 \
    jq \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcairo2 \
    libdbus-1-3 \
    libdbus-glib-1-2 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnss3 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libxshmfence1 \
    libxt6 \
    procps \
    python3 \
    systemd \
    systemd-sysv \
    unzip \
    wget \
    zip \
    && rm -rf /var/lib/apt/lists/*

RUN arch="$(dpkg --print-architecture)" \
    && case "$arch" in \
        amd64) firefox_os='linux64'; geckodriver_arch='linux64' ;; \
        arm64) firefox_os='linux64-aarch64'; geckodriver_arch='linux-aarch64' ;; \
        *) echo "Unsupported architecture: $arch" >&2; exit 1 ;; \
       esac \
    && wget -qO /tmp/firefox.tar.xz "https://download.mozilla.org/?product=firefox-devedition-latest-ssl&os=${firefox_os}&lang=en-US" \
    && tar -xf /tmp/firefox.tar.xz -C /opt \
    && ln -sf /opt/firefox/firefox /usr/local/bin/firefox \
    && wget -qO /tmp/geckodriver.tar.gz "https://github.com/mozilla/geckodriver/releases/download/v${GECKODRIVER_VERSION}/geckodriver-v${GECKODRIVER_VERSION}-${geckodriver_arch}.tar.gz" \
    && tar -xzf /tmp/geckodriver.tar.gz -C /usr/local/bin \
    && chmod +x /usr/local/bin/geckodriver \
    && rm -f /tmp/firefox.tar.xz /tmp/geckodriver.tar.gz

RUN rm -f /lib/systemd/system/multi-user.target.wants/* \
    /etc/systemd/system/*.wants/* \
    /lib/systemd/system/local-fs.target.wants/* \
    /lib/systemd/system/sockets.target.wants/*udev* \
    /lib/systemd/system/sockets.target.wants/*initctl* \
    /lib/systemd/system/sysinit.target.wants/systemd-tmpfiles-setup* \
    /lib/systemd/system/systemd-update-utmp*

RUN systemctl mask systemd-resolved.service systemd-resolved.socket || true

WORKDIR /openpath

COPY VERSION ./VERSION
COPY linux/ ./linux/
COPY runtime/ ./runtime/
COPY windows/ ./windows/
COPY tests/e2e/ ./tests/e2e/
COPY tests/selenium/package.json ./tests/selenium/package.json
COPY tests/selenium/package-lock.json ./tests/selenium/package-lock.json
COPY tests/selenium/tsconfig.json ./tests/selenium/tsconfig.json
COPY tests/selenium/*.ts ./tests/selenium/
COPY firefox-extension/manifest.json ./firefox-extension/manifest.json
COPY firefox-extension/dist/ ./firefox-extension/dist/
COPY firefox-extension/popup/ ./firefox-extension/popup/
COPY firefox-extension/blocked/ ./firefox-extension/blocked/
COPY firefox-extension/native/ ./firefox-extension/native/
COPY firefox-extension/icons/ ./firefox-extension/icons/

RUN cd /openpath/tests/selenium && npm install

RUN find linux tests/e2e -type f -name "*.sh" -exec chmod +x {} +

RUN cd /openpath/firefox-extension \
    && zip -qr openpath-firefox-extension.xpi manifest.json dist popup blocked native icons

STOPSIGNAL SIGRTMIN+3
VOLUME ["/sys/fs/cgroup"]
CMD ["/lib/systemd/systemd"]
