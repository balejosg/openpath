FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

COPY linux/lib/apt.sh /tmp/openpath-apt.sh
RUN . /tmp/openpath-apt.sh \
    && apt_install_with_retry "BATS runner packages" apt-get install -y \
    bats \
    curl \
    dnsutils \
    netcat-openbsd \
    jq \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /tests

COPY tests/ /tests/

CMD ["bats", "--formatter", "tap", "/tests/e2e/agent-integration.bats"]
