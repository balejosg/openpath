{
  "name": "@openpath/shared",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./classroom-status": {
      "types": "./dist/classroom-status.d.ts",
      "import": "./dist/classroom-status.js"
    },
    "./domain": {
      "types": "./dist/domain.d.ts",
      "import": "./dist/domain.js"
    },
    "./slug": {
      "types": "./dist/slug.d.ts",
      "import": "./dist/slug.js"
    },
    "./rules-validation": {
      "types": "./dist/rules-validation.d.ts",
      "import": "./dist/rules-validation.js"
    },
    "./roles": {
      "types": "./dist/roles.d.ts",
      "import": "./dist/roles.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "clean:all": "rm -rf dist *.tsbuildinfo",
    "prebuild": "npm run clean:all",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings=0",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:coverage": "node ../scripts/run-c8-coverage.js \"node --import tsx --test tests/*.test.ts\""
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.10.2",
    "c8": "^11.0.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "c8": {
    "check-coverage": true,
    "lines": 65,
    "functions": 65,
    "branches": 55,
    "reporter": [
      "text",
      "lcov",
      "json"
    ],
    "include": [
      "src/**/*.ts"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
