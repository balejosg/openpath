# Whitelist System Default Configuration
# This file contains defaults that can be overridden at install time via debconf
# or post-install via /var/lib/url-whitelist/*.conf files

# Default whitelist URL
# Empty by default: configure explicitly during enrollment or installation.
WHITELIST_URL=

# Health API (optional, leave empty if not used)
HEALTH_API_URL=
HEALTH_API_SECRET=
