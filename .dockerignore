# Dependencies
**/node_modules

# Build output
**/dist
**/coverage
**/.turbo
**/.vite
**/.eslintcache
**/*.tsbuildinfo

# Test artifacts
**/test-results
**/playwright-report

# Dev/test sources (not needed for image builds)
**/tests
**/e2e
.github
.vscode

# Local env / secrets
.env*
!**/.env.example

# VCS
.git
.gitignore
.gitattributes

# Logs
**/*.log

# OS
.DS_Store

# Required for Linux E2E Docker image (tests/e2e/Dockerfile)
!tests/
tests/**
!tests/e2e/
!tests/e2e/**

# Linux E2E validates release artifacts for the Firefox extension
!firefox-extension/dist/
!firefox-extension/dist/**
