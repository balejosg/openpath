{
  "name": "@openpath/dashboard",
  "version": "1.0.0",
  "description": "Portal web para gestión de OpenPath DNS",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist coverage",
    "clean:all": "rm -rf dist coverage *.tsbuildinfo",
    "prebuild": "npm run clean:all",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "NODE_ENV=test node --import tsx --test --test-force-exit --test-concurrency=1 tests/*.test.ts",
    "test:coverage": "NODE_ENV=test node ../scripts/run-c8-coverage.js \"node --import tsx --test --test-force-exit --test-concurrency=1 tests/*.test.ts\""
  },
  "dependencies": {
    "@openpath/api": "file:../api",
    "@openpath/shared": "file:../shared",
    "@trpc/client": "^11.12.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "c8": "^10.1.3",
    "eslint": "^9.17.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "c8": {
    "check-coverage": true,
    "lines": 50,
    "functions": 35,
    "branches": 50,
    "reporter": [
      "text",
      "lcov",
      "json"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/types/**"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
